# ═══════════════════════════════════════════════════════════════════
#  ECCELLERE — PRODUCTION ENVIRONMENT TEMPLATE
#  This is the CANONICAL list of every env var the production app
#  reads. Paste these (with real values) into:
#    hPanel → Websites → eccellere.co.in → Node.js
#         → Application → Environment Variables
#
#  NEVER commit the actual .env file to git.
# ═══════════════════════════════════════════════════════════════════

# ── Database (MySQL on Hostinger) ──────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL="mysql://u911413127_eccellere:STRONG_PASSWORD@127.0.0.1:3306/u911413127_eccellere"

# ── NextAuth ───────────────────────────────────────────────────────
NEXTAUTH_URL="https://eccellere.co.in"
# Generate with:  openssl rand -base64 48
# (Changing this value logs every user out.)
NEXTAUTH_SECRET="REPLACE_WITH_64_CHAR_RANDOM_SECRET"

# Optional: separate token for /api/admin/setup. Falls back to
# NEXTAUTH_SECRET if unset.
ADMIN_SETUP_TOKEN=""

# ── Razorpay (Payment Gateway) ─────────────────────────────────────
# Dashboard → Settings → API Keys
RAZORPAY_KEY_ID="rzp_live_XXXXXXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_XXXXXXXXXXXXXXXX"
# Dashboard → Webhooks → secret
RAZORPAY_WEBHOOK_SECRET="REPLACE_WITH_RAZORPAY_WEBHOOK_SECRET"

# ── Email (SMTP — Hostinger business email) ────────────────────────
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="contact@eccellere.co.in"
SMTP_PASS="YOUR_EMAIL_PASSWORD"
EMAIL_FROM="contact@eccellere.co.in"

# ── AI (Groq) ──────────────────────────────────────────────────────
# Required for Specialist asset analyse / generate routes.
GROQ_API_KEY="gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ── Storage ────────────────────────────────────────────────────────
# "local" stores uploads on disk under public/uploads (default, OK on Hostinger)
# "s3" requires the AWS_* keys below.
STORAGE_PROVIDER="local"

# Required only if STORAGE_PROVIDER="s3":
# AWS_S3_BUCKET="eccellere-assets"
# AWS_REGION="ap-south-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# CDN_DOMAIN=""

# ── Google OAuth (optional — leave blank to disable Google sign-in) ─
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Analytics / Observability (all optional) ───────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""

# ── Application ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://eccellere.co.in"
NODE_ENV="production"
